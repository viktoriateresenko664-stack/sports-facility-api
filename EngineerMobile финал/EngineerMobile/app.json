      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.engineermobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "appDomain": "sports-facilities-monitoring",
      "appDisplayName": "Engineer Mobile",
      "eas": {
        "projectId": "db408149-e107-4e34-b01a-55cb74350a81"
      }
    }
