APP_NAME=Sports Facilities Monitoring API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require
REDIS_URL=redis://localhost:6379/0
SENSOR_SOURCE_MODE=fake_only
SENSOR_SIMULATOR_ENABLED=false
SENSOR_AUTOGEN_ENABLED=true
ENABLE_REQUEST_METRICS=false
ENABLE_BFF_CACHE=false
ENABLE_DEV_ENDPOINTS=true
RATE_LIMIT_DEFAULT_PER_MINUTE=100
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=5
RATE_LIMIT_AUTH_EMPLOYEE_LOGIN_PER_MINUTE=5
RATE_LIMIT_AUTH_REGISTER_PER_MINUTE=3
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100
LOGIN_BRUTEFORCE_MAX_ATTEMPTS=5
LOGIN_BRUTEFORCE_BLOCK_SECONDS=600
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://localhost:19006,http://127.0.0.1:19006
CORS_ALLOW_ORIGIN_REGEX=https://.*\.ngrok(-free)?\.(app|dev)
# Production example:
# APP_ENV=production
# DEBUG=false
# ENABLE_DEV_ENDPOINTS=false
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-frontend.netlify.app
# CORS_ALLOW_ORIGIN_REGEX=
REPORTS_STORAGE_DIR=storage/reports
REPORT_TEMPLATE_FILENAME=engineer_report_template.txt
REPORT_UPLOAD_MAX_SIZE_BYTES=10485760
REPORTS_ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.txt,.md,.rtf,.csv,.jpg,.jpeg,.png
